# .gitignore for Python/FastAPI Project

# Environment Variables - CRITICAL
.env
.env.*
!.env.example
*.env

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual Environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.spyderproject
.spyproject

# PyCharm
.idea/
*.iml
*.iws
.idea_modules/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Distribution / Packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Database
*.db
*.sqlite
*.sqlite3
*.sql

# Logs
*.log
logs/
*.log.*

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Temporary Files
*.tmp
*.temp
*.bak
*.swp
*.swo

# Supabase (if using local development)
supabase/.branches
supabase/.temp

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# pytype
.pytype/

# Secrets and Keys
*.pem
*.key
*.cert
*.crt
secrets.json
credentials.json

# Environment-specific
local_settings.py
.envrc

# Documentation builds
docs/_build/
site/

# Media/Upload folders (if applicable)
media/
uploads/
static/uploaded/

# Node modules (if you have any frontend)
node_modules/
npm-debug.log
yarn-error.log

# Backup files
*.bkp
*.backup
.env.example
